{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoltYTM",
  "version": "1.0.0",
  "identifier": "com.rixabhh.voltytm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "corepack pnpm run dev",
    "beforeBuildCommand": "corepack pnpm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["themes/*"],
    "category": "Music",
    "shortDescription": "A fast native desktop app for YouTube Music with plugins, media controls, and ad blocking.",
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "music.youtube.com",
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    }
  }
}
